{
  "name": "railway-deployer",
  "version": "1.0.0",
  "description": "Deploy multiple apps to Railway with git branch/commit support",
  "type": "module",
  "scripts": {
    "start": "bun run src/index.ts",
    "dev": "bun --watch src/index.ts",
    "db:migrate": "bun run src/db/migrate.ts"
  },
  "dependencies": {
    "drizzle-orm": "^0.29.0",
    "postgres": "^3.4.0"
  },
  "devDependencies": {
    "bun-types": "^1.1.0",
    "typescript": "^5.3.0"
  },
  "bin": {
    "railway-deploy": "./bin/railway-deploy"
  }
}
